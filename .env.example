DEBUG=true

DATABASE_URL=postgresql+asyncpg://userservice:userservice@localhost:5432/userservice
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-local-dev-only
ALGORITHM=HS256
JWT_ISSUER=scalable-user-service
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=10
REDIS_MAX_CONNECTIONS=100

ENABLE_RATE_LIMITING=true
RATE_LIMIT_TRUST_PROXY_HEADERS=false
RATE_LIMIT_SIGNUP=5/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_FORGOT_PASSWORD=5/minute
RATE_LIMIT_RESET_PASSWORD=5/minute
RATE_LIMIT_VERIFY_EMAIL=5/minute
RATE_LIMIT_RESEND_VERIFICATION=5/minute

PROFILE_CACHE_TTL_SECONDS=300
OTP_TTL_SECONDS=900
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_SECONDS=900

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true

EMAIL_DELIVERY_ENABLED=false
RESEND_API_KEY=
EMAIL_FROM=noreply@example.com
FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000
